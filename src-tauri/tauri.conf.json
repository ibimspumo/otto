{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Otto",
  "version": "0.2.1",
  "identifier": "de.agentz.otto",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Otto",
        "width": 280,
        "height": 104,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true,
        "visible": false
      },
      {
        "label": "panel",
        "title": "Otto",
        "url": "index.html?panel=1",
        "width": 352,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "acceptFirstMouse": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Otto",
        "url": "index.html?settings=1",
        "width": 820,
        "height": 600,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: https://icons.duckduckgo.com; media-src 'self' data: blob:; frame-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost https://api.openai.com wss://api.openai.com https://api.search.brave.com https://openrouter.ai https://*.openrouter.ai;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGNjBCQTIwMDAwRDdBQzAKUldUQWVnMEFJTHBndi9oZllFSzBkQmYwUTNkMGlJb3dIL3MrazM0SkQvUm1BQlEzRmFiaVNHYjMK",
      "endpoints": [
        "https://github.com/ibimspumo/otto/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
