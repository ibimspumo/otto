{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Otto",
  "version": "0.4.0",
  "identifier": "de.agentz.otto",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Otto",
        "width": 1400,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0c10"
      },
      {
        "label": "mini",
        "title": "Otto",
        "url": "index.html?mini=1",
        "width": 240,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGNjBCQTIwMDAwRDdBQzAKUldUQWVnMEFJTHBndi9oZllFSzBkQmYwUTNkMGlJb3dIL3MrazM0SkQvUm1BQlEzRmFiaVNHYjMK",
      "endpoints": [
        "https://github.com/ibimspumo/otto/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
